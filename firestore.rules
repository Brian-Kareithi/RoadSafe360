rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isPolice() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'police';
    }
    function isDriver() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }
    function isAuthority() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'authority';
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPolice();
    }

    match /licences/{licenceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /policeOfficers/{officerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /offenceCategories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /offences/{offenceId} {
      allow read: if isAuthenticated();
      allow create: if isPolice() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /appeals/{appealId} {
      allow read: if isAuthenticated();
      allow create: if isDriver() || isAdmin();
      allow update: if isAdmin() || isAuthority();
    }

    match /suspensionHistory/{suspensionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /regions/{regionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAuthority();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin() || isAuthority();
      allow write: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPolice();
    }

    match /demeritHistory/{historyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
